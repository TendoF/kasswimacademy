<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
/* ── NAVBAR SCROLL ── */
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
});

/* ── MOBILE MENU ── */
function toggleMenu() {
  const btn = document.getElementById('menuBtn');
  const nav = document.getElementById('mobileNav');
  btn.classList.toggle('open');
  nav.classList.toggle('open');
  document.body.style.overflow = nav.classList.contains('open') ? 'hidden' : '';
}
function closeMenu() {
  document.getElementById('menuBtn').classList.remove('open');
  document.getElementById('mobileNav').classList.remove('open');
  document.body.style.overflow = '';
}

/* ── PROMO COUNTDOWN ── */
(function() {
  const END = new Date('2026-04-01T00:00:00');
  const now = new Date();
  const promoSection = document.getElementById('promo');
  const el = document.getElementById('daysLeft');
  if (now >= END) {
    if (promoSection) promoSection.style.display = 'none';
    return;
  }
  const days = Math.ceil((END - now) / (1000 * 60 * 60 * 24));
  if (el) el.textContent = days;
})();

/* ── SCROLL REVEAL ── */
(function() {
  const els = document.querySelectorAll('.reveal, .reveal-l, .reveal-r');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('on'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.07 });
  els.forEach(el => obs.observe(el));
})();

/* ── CONTACT FORM ── */
function getFormData() {
  return {
    fname:   document.getElementById('cf-fname').value.trim(),
    lname:   document.getElementById('cf-lname').value.trim(),
    phone:   document.getElementById('cf-phone').value.trim(),
    email:   document.getElementById('cf-email').value.trim(),
    service: document.getElementById('cf-service').value,
    time:    document.getElementById('cf-time').value,
    message: document.getElementById('cf-message').value.trim(),
  };
}
function validateForm() {
  const d = getFormData();
  if (!d.fname) { alert('Please enter your first name.'); document.getElementById('cf-fname').focus(); return false; }
  if (!d.phone) { alert('Please enter your phone or WhatsApp number.'); document.getElementById('cf-phone').focus(); return false; }
  return true;
}
function buildMessage(d) {
  const name = d.fname + (d.lname ? ' ' + d.lname : '');
  let msg = `Hi KAS Swim Academy! 👋\n\n`;
  msg += `*Name:* ${name}\n*Phone:* ${d.phone}\n`;
  if (d.email)   msg += `*Email:* ${d.email}\n`;
  if (d.service) msg += `*Interested In:* ${d.service}\n`;
  if (d.time)    msg += `*Preferred Time:* ${d.time}\n`;
  if (d.message) msg += `\n*Message:*\n${d.message}`;
  return msg;
}
function sendViaWhatsApp() {
  if (!validateForm()) return;
  const d = getFormData();
  window.open(`https://wa.me/263719809967?text=${encodeURIComponent(buildMessage(d))}`, '_blank');
  showSuccess(d.fname, 'WhatsApp');
}
function sendViaEmail() {
  if (!validateForm()) return;
  const d = getFormData();
  const name = d.fname + (d.lname ? ' ' + d.lname : '');
  const subject = encodeURIComponent(`KAS Swim Academy Enquiry — ${d.service || 'General'}`);
  let body = `Hi KAS Swim Academy,\n\nName: ${name}\nPhone: ${d.phone}\n`;
  if (d.email)   body += `Email: ${d.email}\n`;
  if (d.service) body += `Interested In: ${d.service}\n`;
  if (d.time)    body += `Preferred Time: ${d.time}\n`;
  if (d.message) body += `\nMessage:\n${d.message}`;
  window.location.href = `mailto:Aquahubwellness@outlook.com?subject=${subject}&body=${encodeURIComponent(body)}`;
  showSuccess(d.fname, 'email');
}
function showSuccess(fname, method) {
  document.getElementById('contactGrid').style.display = 'none';
  const el = document.getElementById('contactSuccess');
  el.style.display = 'block';
  document.getElementById('successMsg').textContent =
    `Thank you, ${fname}! ${method === 'WhatsApp' ? 'Your WhatsApp message is prepared — just hit send!' : 'Your email app should open with the message ready to send.'} We'll get back to you very soon.`;
  document.getElementById('contact').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function resetForm() {
  document.getElementById('contactGrid').style.display = '';
  document.getElementById('contactSuccess').style.display = 'none';
  ['cf-fname','cf-lname','cf-phone','cf-email','cf-message'].forEach(id => { document.getElementById(id).value = ''; });
  document.getElementById('cf-service').selectedIndex = 0;
  document.getElementById('cf-time').selectedIndex = 0;
}
