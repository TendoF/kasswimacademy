<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KAS Swim Academy — Elite Aquatic Training | Harare, Zimbabwe</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   ROOT & RESET
══════════════════════════════════════════ */
:root {
  --ink:      #050d18;
  --navy:     #071828;
  --deep:     #0a2540;
  --ocean:    #0e4a7a;
  --blue:     #1166cc;
  --sky:      #1a8fe3;
  --cyan:     #00c4e8;
  --ice:      #e0f7ff;
  --white:    #ffffff;
  --gold:     #f0b429;
  --text:     rgba(255,255,255,0.65);
  --text-med: rgba(255,255,255,0.82);
  --border:   rgba(0,196,232,0.14);
  --border-b: rgba(255,255,255,0.07);
  --glass:    rgba(255,255,255,0.04);
  --rad:      20px;
  --rad-sm:   12px;
  --rad-lg:   28px;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:16px; overflow-x:hidden; }
body {
  font-family:'DM Sans', sans-serif;
  background:var(--ink);
  color:var(--white);
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
img { display:block; max-width:100%; height:auto; }
a { text-decoration:none; color:inherit; }
button { font-family:inherit; }

/* ══════════════════════════════════════════
   SCROLLBAR
══════════════════════════════════════════ */
::-webkit-scrollbar { width:5px; }
::-webkit-scrollbar-track { background:var(--ink); }
::-webkit-scrollbar-thumb { background:var(--cyan); border-radius:10px; }

/* ══════════════════════════════════════════
   NOISE OVERLAY
══════════════════════════════════════════ */
body::before {
  content:'';
  position:fixed; inset:0; z-index:0; pointer-events:none;
  opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:200px;
}

/* ══════════════════════════════════════════
   NAVBAR
══════════════════════════════════════════ */
#navbar {
  position:fixed; top:0; left:0; right:0; z-index:900;
  display:flex; align-items:center; justify-content:space-between;
  padding:1.1rem 5%;
  background:rgba(5,13,24,0);
  transition:padding .4s ease, background .4s ease, border .4s ease;
}
#navbar.scrolled {
  padding:.75rem 5%;
  background:rgba(5,13,24,0.94);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);
}
.nav-logo {
  display:flex; align-items:center; gap:.7rem;
  font-family:'Syne', sans-serif; font-weight:800; font-size:1.35rem;
  letter-spacing:-.02em;
}
.nav-logo-mark {
  width:40px; height:40px; border-radius:10px;
  background:linear-gradient(135deg, var(--blue), var(--cyan));
  display:flex; align-items:center; justify-content:center;
  font-weight:800; font-size:1rem; color:var(--ink);
  box-shadow:0 4px 16px rgba(0,196,232,0.35);
  flex-shrink:0;
}
.nav-logo span { color:var(--cyan); }
.nav-links {
  display:flex; align-items:center; gap:2.4rem; list-style:none;
}
.nav-links a {
  font-family:'Syne', sans-serif; font-size:.8rem; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase;
  color:rgba(255,255,255,0.6); transition:color .2s;
}
.nav-links a:hover { color:var(--cyan); }
.nav-cta {
  background:linear-gradient(135deg, var(--blue), var(--cyan)) !important;
  color:var(--ink) !important;
  padding:.55rem 1.5rem; border-radius:50px;
  box-shadow:0 4px 20px rgba(0,196,232,0.3);
  transition:box-shadow .2s, transform .2s !important;
}
.nav-cta:hover {
  box-shadow:0 8px 36px rgba(0,196,232,0.55) !important;
  transform:translateY(-1px) !important;
  color:var(--ink) !important;
}
.hamburger {
  display:none; flex-direction:column; gap:5px;
  cursor:pointer; background:none; border:none; padding:.4rem;
}
.hamburger span {
  display:block; width:24px; height:2px;
  background:var(--cyan); border-radius:2px;
  transition:.3s ease;
}
.hamburger.open span:nth-child(1) { transform:rotate(45deg) translate(5px,5px); }
.hamburger.open span:nth-child(2) { opacity:0; width:0; }
.hamburger.open span:nth-child(3) { transform:rotate(-45deg) translate(5px,-5px); }

.mobile-nav {
  display:none; position:fixed;
  top:0; left:0; right:0; bottom:0; z-index:899;
  background:rgba(5,13,24,0.98);
  flex-direction:column; align-items:center; justify-content:center;
  gap:2rem;
  backdrop-filter:blur(20px);
  padding:5rem 5%;
}
.mobile-nav.open { display:flex; }
.mobile-nav a {
  font-family:'Syne', sans-serif; font-size:1.6rem; font-weight:700;
  color:rgba(255,255,255,0.7); letter-spacing:.04em;
  transition:color .2s, transform .2s;
}
.mobile-nav a:hover { color:var(--cyan); transform:translateX(8px); }
.mobile-nav-close {
  position:absolute; top:1.5rem; right:5%;
  background:none; border:none; cursor:pointer;
  color:var(--cyan); font-size:1.5rem; padding:.5rem;
}

/* ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ */
#home {
  position:relative; min-height:100vh;
  display:flex; align-items:center;
  overflow:hidden; padding:6rem 5% 4rem;
  background: radial-gradient(ellipse 80% 60% at 60% 40%, #0e2e55 0%, var(--ink) 70%);
}
.hero-bg-img {
  position:absolute; inset:0; z-index:0;
  background:url('https://images.unsplash.com/photo-1530549387789-4c1017266635?w=1800&q=80&auto=format&fit=crop') center/cover no-repeat;
  opacity:.12;
}
.hero-bg-img::after {
  content:''; position:absolute; inset:0;
  background: linear-gradient(to right, var(--ink) 0%, transparent 55%, var(--ink) 100%),
              linear-gradient(to top, var(--ink) 0%, transparent 60%);
}
/* animated wave lines */
.hero-lines {
  position:absolute; inset:0; z-index:1; pointer-events:none; overflow:hidden;
}
.hero-lines svg {
  position:absolute; bottom:0; left:0; width:100%; opacity:.18;
}
.hero-glow {
  position:absolute; top:10%; right:5%; z-index:1; pointer-events:none;
  width:clamp(300px,45vw,700px); height:clamp(300px,45vw,700px);
  border-radius:50%;
  background:radial-gradient(circle, rgba(0,196,232,0.12) 0%, transparent 65%);
  animation:glowFloat 7s ease-in-out infinite;
}
@keyframes glowFloat {
  0%,100%{transform:translate(0,0) scale(1);}
  50%{transform:translate(-20px,15px) scale(1.06);}
}
.hero-inner {
  position:relative; z-index:2;
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(2rem,5vw,5rem); align-items:center;
  max-width:1200px; width:100%; margin:0 auto;
}
.hero-text {}
.hero-badge {
  display:inline-flex; align-items:center; gap:.5rem;
  font-family:'Syne',sans-serif; font-size:.68rem; font-weight:700;
  letter-spacing:.2em; text-transform:uppercase; color:var(--cyan);
  border:1px solid rgba(0,196,232,0.35); padding:.35rem 1rem;
  border-radius:50px; margin-bottom:1.5rem;
  animation:fadeUp .8s ease both;
}
.hero-h1 {
  font-family:'Instrument Serif', serif;
  font-size:clamp(2.5rem, 5.5vw, 5rem);
  font-weight:400; line-height:1.05;
  margin-bottom:1.2rem;
  animation:fadeUp .8s .1s ease both;
}
.hero-h1 .accent { color:var(--cyan); font-style:italic; }
.hero-h1 .block {
  display:block; font-size:.55em; font-family:'Syne',sans-serif;
  font-weight:700; letter-spacing:.08em; color:rgba(255,255,255,.5);
  font-style:normal; margin-bottom:.3rem; text-transform:uppercase;
}
.hero-p {
  font-size:clamp(.9rem,1.5vw,1.05rem); color:var(--text);
  line-height:1.8; max-width:500px; margin-bottom:2.2rem;
  animation:fadeUp .8s .2s ease both;
}
.hero-btns {
  display:flex; gap:1rem; flex-wrap:wrap;
  animation:fadeUp .8s .3s ease both;
}
.btn-primary {
  display:inline-flex; align-items:center; gap:.55rem;
  background:linear-gradient(135deg, var(--blue), var(--cyan));
  color:var(--ink); font-family:'Syne',sans-serif;
  font-weight:700; font-size:.88rem; letter-spacing:.04em;
  padding:.9rem 2.2rem; border-radius:50px; border:none; cursor:pointer;
  box-shadow:0 6px 30px rgba(0,196,232,0.35);
  transition:transform .2s, box-shadow .2s;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 10px 44px rgba(0,196,232,0.55); }
.btn-ghost {
  display:inline-flex; align-items:center; gap:.55rem;
  border:1.5px solid rgba(0,196,232,0.4); color:var(--cyan);
  font-family:'Syne',sans-serif; font-weight:700; font-size:.88rem;
  letter-spacing:.04em; padding:.9rem 2.2rem; border-radius:50px;
  transition:background .2s, border-color .2s;
  cursor:pointer; background:none;
}
.btn-ghost:hover { background:rgba(0,196,232,0.1); border-color:rgba(0,196,232,0.7); }
/* Hero image card */
.hero-img-col {
  position:relative;
  animation:fadeRight .9s .15s ease both;
}
.hero-img-frame {
  border-radius:24px; overflow:hidden;
  aspect-ratio:4/5;
  box-shadow:0 40px 100px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,196,232,0.12);
  position:relative;
}
.hero-img-frame img { width:100%; height:100%; object-fit:cover; display:block; }
.hero-img-frame::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(to top, rgba(5,13,24,.6) 0%, transparent 50%);
}
.hero-img-tag {
  position:absolute; bottom:1.6rem; left:1.6rem; z-index:2;
  display:flex; align-items:center; gap:.7rem;
  background:rgba(5,13,24,0.85); border:1px solid rgba(0,196,232,0.2);
  backdrop-filter:blur(12px); border-radius:50px;
  padding:.55rem 1.2rem .55rem .55rem;
}
.hero-img-tag-dot {
  width:8px; height:8px; border-radius:50%; background:var(--cyan);
  animation:pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,196,232,.6);} 50%{box-shadow:0 0 0 6px rgba(0,196,232,0);} }
.hero-img-tag span { font-size:.78rem; font-weight:600; color:rgba(255,255,255,0.85); }
.hero-stat-float {
  position:absolute; top:-1.4rem; left:-1.4rem;
  background:var(--deep); border:1px solid rgba(0,196,232,0.2);
  backdrop-filter:blur(12px); border-radius:18px;
  padding:1.1rem 1.4rem;
  box-shadow:0 16px 48px rgba(0,0,0,0.4);
  animation:statFloat 5s ease-in-out infinite;
  min-width:130px;
}
@keyframes statFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-8px);} }
.hero-stat-num {
  font-family:'Instrument Serif',serif; font-size:2.2rem;
  background:linear-gradient(135deg,var(--sky),var(--cyan));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; line-height:1;
}
.hero-stat-lbl { font-size:.72rem; color:var(--text); margin-top:.3rem; line-height:1.4; }
.hero-wave { position:absolute; bottom:0; left:0; width:100%; line-height:0; z-index:3; }
.hero-wave svg { display:block; width:100%; }
@keyframes fadeUp { from{opacity:0;transform:translateY(32px);} to{opacity:1;transform:translateY(0);} }
@keyframes fadeRight { from{opacity:0;transform:translateX(40px);} to{opacity:1;transform:translateX(0);} }

/* ══════════════════════════════════════════
   MARQUEE / TICKER
══════════════════════════════════════════ */
.ticker-wrap {
  background:linear-gradient(90deg, var(--blue), var(--cyan), var(--blue));
  background-size:200% 100%;
  animation:tickerBg 4s linear infinite;
  padding:.7rem 0; overflow:hidden; position:relative; z-index:5;
}
@keyframes tickerBg { 0%{background-position:0%} 100%{background-position:200%} }
.ticker-inner {
  display:flex; gap:0; white-space:nowrap;
  animation:tickerScroll 28s linear infinite;
}
.ticker-inner:hover { animation-play-state:paused; }
@keyframes tickerScroll { 0%{transform:translateX(0);} 100%{transform:translateX(-50%);} }
.ticker-item {
  display:inline-flex; align-items:center; gap:.6rem;
  padding:0 2rem; font-family:'Syne',sans-serif;
  font-size:.75rem; font-weight:700; letter-spacing:.1em;
  text-transform:uppercase; color:var(--ink);
}
.ticker-dot { width:5px; height:5px; border-radius:50%; background:var(--ink); opacity:.5; flex-shrink:0; }

/* ══════════════════════════════════════════
   SHARED SECTION STYLES
══════════════════════════════════════════ */
section { padding:clamp(4rem,8vw,7rem) 5%; width:100%; position:relative; z-index:1; }
.container { max-width:1200px; margin:0 auto; width:100%; }
.section-tag {
  display:inline-block; font-family:'Syne',sans-serif;
  font-size:.68rem; font-weight:700; letter-spacing:.2em;
  text-transform:uppercase; color:var(--cyan); margin-bottom:.6rem;
}
.section-h2 {
  font-family:'Instrument Serif', serif;
  font-size:clamp(2rem,4vw,3.2rem); font-weight:400;
  color:var(--white); line-height:1.12; margin-bottom:.9rem;
}
.section-h2 em { color:var(--cyan); font-style:italic; }
.section-sub {
  color:var(--text); line-height:1.82;
  font-size:clamp(.88rem,1.5vw,1rem); max-width:560px;
}
.section-head { margin-bottom:3.5rem; }
.centered { text-align:center; }
.centered .section-sub { margin:0 auto; }
/* dividers */
.wdiv { line-height:0; overflow:hidden; width:100%; position:relative; z-index:2; }
.wdiv svg { display:block; width:100%; }

/* ══════════════════════════════════════════
   ABOUT
══════════════════════════════════════════ */
#about {
  background:linear-gradient(170deg, var(--ink) 0%, var(--navy) 100%);
}
.about-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(2rem,5vw,5rem); align-items:center;
}
.about-img-col { position:relative; padding-bottom:2rem; }
.about-img-stack { position:relative; }
.about-img-main {
  border-radius:var(--rad-lg); overflow:hidden;
  aspect-ratio:4/5;
  box-shadow:0 40px 100px rgba(0,0,0,.55), 0 0 0 1px var(--border);
  position:relative;
}
.about-img-main img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; }
.about-img-main:hover img { transform:scale(1.04); }
.about-img-secondary {
  position:absolute; bottom:-1.8rem; right:-1.8rem;
  width:55%; border-radius:var(--rad); overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.55), 0 0 0 3px rgba(0,196,232,.1);
  aspect-ratio:3/2;
}
.about-img-secondary img { width:100%; height:100%; object-fit:cover; display:block; }
.about-badge {
  position:absolute; top:-1.2rem; left:-1.2rem;
  background:linear-gradient(135deg, var(--gold), #f5c842);
  color:#1a0e00; font-weight:700; font-size:.78rem;
  padding:1rem 1.3rem; border-radius:var(--rad-sm);
  box-shadow:0 8px 32px rgba(240,180,41,.4);
  line-height:1.5; z-index:5;
}
.about-badge strong { display:block; font-family:'Syne',sans-serif; font-size:1.4rem; }
.about-text p {
  color:var(--text); line-height:1.9; margin-bottom:1.2rem;
  font-size:clamp(.88rem,1.5vw,1rem);
}
.about-highlights { display:flex; flex-direction:column; gap:.75rem; margin:1.8rem 0; }
.about-hl {
  display:flex; align-items:center; gap:.85rem;
  padding:1rem 1.2rem; border-radius:var(--rad-sm);
  background:rgba(0,196,232,.05); border:1px solid var(--border);
  transition:background .2s, transform .2s;
}
.about-hl:hover { background:rgba(0,196,232,.1); transform:translateX(5px); }
.about-hl-icon {
  width:36px; height:36px; border-radius:10px; flex-shrink:0;
  background:rgba(0,196,232,.1); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  color:var(--cyan);
}
.about-hl-text strong { display:block; font-size:.88rem; color:var(--white); margin-bottom:.1rem; }
.about-hl-text span { font-size:.78rem; color:var(--text); }

/* ══════════════════════════════════════════
   SERVICES
══════════════════════════════════════════ */
#services { background:var(--navy); }
.services-grid {
  display:grid; grid-template-columns:repeat(auto-fit,minmax(min(100%,270px),1fr));
  gap:1.4rem;
}
.svc-card {
  background:var(--glass); border:1px solid var(--border);
  border-radius:var(--rad-lg); overflow:hidden;
  transition:transform .3s, box-shadow .3s, border-color .3s;
  position:relative;
}
.svc-card:hover {
  transform:translateY(-8px);
  box-shadow:0 28px 72px rgba(0,0,0,.45);
  border-color:rgba(0,196,232,.35);
}
.svc-card-img {
  height:200px; overflow:hidden; position:relative;
}
.svc-card-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; }
.svc-card:hover .svc-card-img img { transform:scale(1.06); }
.svc-card-img::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(to top, rgba(7,24,40,.8) 0%, transparent 55%);
}
.svc-card-body { padding:1.6rem; }
.svc-num {
  font-family:'Instrument Serif',serif; font-size:2.5rem; opacity:.1;
  position:absolute; top:1rem; right:1.2rem; line-height:1;
  color:var(--cyan); pointer-events:none;
}
.svc-icon {
  width:44px; height:44px; border-radius:12px;
  background:rgba(0,196,232,.1); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  color:var(--cyan); margin-bottom:1rem;
}
.svc-title {
  font-family:'Syne',sans-serif; font-size:1.05rem; font-weight:700;
  margin-bottom:.6rem; color:var(--white);
}
.svc-desc {
  font-size:.86rem; color:var(--text); line-height:1.75; margin-bottom:1rem;
}
.svc-tags { display:flex; flex-wrap:wrap; gap:.35rem; }
.stag {
  font-size:.65rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase;
  padding:.25rem .65rem; border-radius:50px;
  background:rgba(0,196,232,.08); color:var(--cyan);
  border:1px solid rgba(0,196,232,.18);
}
/* featured service card */
.svc-card.featured {
  grid-column:span 2;
  display:grid; grid-template-columns:1fr 1fr;
}
.svc-card.featured .svc-card-img { height:auto; min-height:260px; }

/* ══════════════════════════════════════════
   WHY KAS
══════════════════════════════════════════ */
#benefits {
  background:linear-gradient(170deg, var(--ink) 0%, rgba(14,74,122,0.12) 100%);
  overflow:hidden; position:relative;
}
#benefits::before {
  content:''; position:absolute; bottom:-200px; left:-200px;
  width:600px; height:600px; border-radius:50%;
  background:radial-gradient(circle, rgba(0,196,232,.05), transparent 65%);
  pointer-events:none;
}
.benefits-layout {
  display:grid; grid-template-columns:44% 1fr;
  gap:clamp(2rem,5vw,5rem); align-items:center;
}
.benefits-lead {
  color:var(--text); line-height:1.85; font-size:clamp(.88rem,1.5vw,1rem);
  margin-bottom:2rem;
}
.bh {
  display:flex; align-items:flex-start; gap:1rem;
  padding:1.2rem 1.4rem; border-radius:var(--rad-sm);
  background:var(--glass); border:1px solid var(--border);
  margin-bottom:.85rem;
  transition:background .3s, transform .2s;
}
.bh:hover { background:rgba(0,196,232,.08); transform:translateX(5px); }
.bh-icon {
  width:42px; height:42px; flex-shrink:0; border-radius:12px;
  background:rgba(0,196,232,.1); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center; color:var(--cyan);
}
.bh-text strong { display:block; font-size:.9rem; margin-bottom:.25rem; color:var(--white); }
.bh-text span { font-size:.82rem; color:var(--text); line-height:1.55; }
.stats-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.stat-card {
  background:var(--glass); border:1px solid var(--border);
  border-radius:var(--rad); padding:1.8rem 1.4rem; text-align:center;
  position:relative; overflow:hidden;
  transition:transform .3s, background .3s;
}
.stat-card::after {
  content:''; position:absolute; bottom:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
  transform:scaleX(0); transform-origin:center; transition:transform .3s;
}
.stat-card:hover { transform:translateY(-5px); background:rgba(0,196,232,.07); }
.stat-card:hover::after { transform:scaleX(1); }
.stat-card.wide { grid-column:1/-1; display:flex; align-items:center; gap:1.4rem; text-align:left; }
.stat-card .icon {
  width:52px; height:52px; border-radius:14px; flex-shrink:0;
  background:rgba(0,196,232,.1); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center; color:var(--cyan);
  margin:0 auto 1rem;
}
.stat-card.wide .icon { margin:0; }
.stat-num {
  font-family:'Instrument Serif',serif; font-size:2.6rem; font-weight:400;
  background:linear-gradient(135deg,var(--sky),var(--cyan));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; line-height:1; margin-bottom:.4rem;
}
.stat-lbl { font-size:.8rem; color:var(--text); line-height:1.5; }
.stat-card.wide .stat-lbl { font-size:.86rem; }

/* ══════════════════════════════════════════
   GALLERY
══════════════════════════════════════════ */
#gallery { padding:0; background:var(--ink); overflow:hidden; }
.gallery-intro { padding:clamp(3rem,6vw,5rem) 5% clamp(2rem,4vw,3rem); text-align:center; }
.gallery-masonry {
  display:grid;
  grid-template-columns:1.5fr 1fr 1fr;
  grid-template-rows:300px 300px;
  gap:3px;
}
.g-item { overflow:hidden; position:relative; cursor:pointer; }
.g-item img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; filter:brightness(.85); }
.g-item:hover img { transform:scale(1.06); filter:brightness(1); }
.g-item::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(to top, rgba(5,13,24,.6) 0%, transparent 50%);
}
.g-item:first-child { grid-row:span 2; }
.g-item-lbl {
  position:absolute; bottom:1.2rem; left:1.4rem; z-index:2;
  opacity:0; transform:translateY(6px); transition:.3s;
}
.g-item:hover .g-item-lbl { opacity:1; transform:translateY(0); }
.g-item-lbl span {
  font-family:'Syne',sans-serif; font-size:.68rem; font-weight:700;
  letter-spacing:.12em; text-transform:uppercase; color:var(--cyan);
  background:rgba(5,13,24,.75); padding:.3rem .8rem; border-radius:50px;
  border:1px solid rgba(0,196,232,.2);
}

/* ══════════════════════════════════════════
   TENNIS
══════════════════════════════════════════ */
#tennis {
  background:linear-gradient(160deg, var(--ink) 0%, #061a0e 100%);
  position:relative; overflow:hidden;
}
#tennis::before {
  content:''; position:absolute; inset:0;
  background-image: repeating-linear-gradient(90deg, rgba(255,255,255,.013) 0,rgba(255,255,255,.013) 1px,transparent 1px,transparent 80px),
                    repeating-linear-gradient(0deg, rgba(255,255,255,.013) 0,rgba(255,255,255,.013) 1px,transparent 1px,transparent 80px);
  pointer-events:none;
}
.tennis-layout {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(2rem,5vw,5rem); align-items:center; position:relative; z-index:1;
}
.tennis-img-frame {
  border-radius:var(--rad-lg); overflow:hidden; aspect-ratio:4/3;
  box-shadow:0 28px 72px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.06);
}
.tennis-img-frame img { width:100%; height:100%; object-fit:cover; display:block; }
.tennis-tag-color { color:#7edb7e !important; }
.tennis-pills { display:flex; flex-wrap:wrap; gap:.5rem; margin:1.4rem 0 2rem; }
.tennis-pill {
  display:inline-flex; align-items:center; gap:.4rem;
  background:rgba(100,210,80,.08); border:1px solid rgba(100,210,80,.2);
  border-radius:50px; padding:.38rem .9rem;
  font-size:.78rem; color:#7edb7e; font-weight:600;
}
.tennis-text p { color:var(--text); line-height:1.85; margin-bottom:1rem; font-size:clamp(.88rem,1.5vw,1rem); }

/* ══════════════════════════════════════════
   MERCH
══════════════════════════════════════════ */
#merch { background:var(--navy); }
.merch-layout {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(2rem,5vw,4rem); align-items:center;
}
.merch-imgs { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
.merch-img {
  border-radius:var(--rad); overflow:hidden;
  position:relative; background:var(--deep);
}
.merch-img:first-child { grid-row:span 2; aspect-ratio:unset; min-height:380px; }
.merch-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; }
.merch-img:hover img { transform:scale(1.04); }
.merch-text p { color:var(--text); line-height:1.85; font-size:clamp(.88rem,1.5vw,1rem); margin-bottom:1rem; }
.merch-feats { display:flex; flex-direction:column; gap:.6rem; margin:1.5rem 0 2rem; }
.merch-feat {
  display:flex; align-items:center; gap:.75rem;
  font-size:.88rem; color:var(--text-med);
}
.merch-feat svg { color:var(--cyan); flex-shrink:0; width:16px; height:16px; }
.merch-badge {
  display:inline-flex; align-items:center; gap:.5rem;
  background:rgba(0,196,232,.07); border:1px solid var(--border);
  border-radius:50px; padding:.4rem 1rem;
  font-family:'Syne',sans-serif; font-size:.68rem; font-weight:700;
  letter-spacing:.1em; text-transform:uppercase; color:var(--cyan);
  margin-bottom:1.2rem;
}

/* ══════════════════════════════════════════
   SCHEDULE & PRICING
══════════════════════════════════════════ */
#schedule { background:linear-gradient(170deg, var(--ink) 0%, var(--navy) 100%); }
.schedule-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(1.5rem,3vw,3rem); align-items:start;
}
.glass-card {
  background:rgba(5,13,24,0.6); border:1px solid var(--border);
  border-radius:var(--rad-lg); padding:clamp(1.5rem,3vw,2.4rem);
  backdrop-filter:blur(4px);
}
.card-h3 {
  font-family:'Syne',sans-serif; font-size:1.1rem; font-weight:700;
  color:var(--cyan); margin-bottom:1.5rem;
  display:flex; align-items:center; gap:.65rem;
}
.day-row {
  display:flex; align-items:center; gap:1rem;
  padding:.85rem 0; border-bottom:1px solid var(--border-b);
}
.day-row:last-child { border-bottom:none; }
.day-dot { width:7px; height:7px; border-radius:50%; background:var(--cyan); flex-shrink:0; }
.day-name { font-weight:600; font-size:.92rem; flex:1; }
.day-time { font-size:.82rem; color:var(--text); text-align:right; line-height:1.6; }
.sched-note {
  margin-top:1.4rem; padding:1rem 1.2rem;
  background:rgba(0,196,232,.06); border:1px solid var(--border);
  border-radius:var(--rad-sm); font-size:.82rem; color:var(--text); line-height:1.7;
}
/* pricing */
.pricing-card { text-align:center; position:relative; overflow:hidden; }
.pricing-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg, var(--blue), var(--cyan));
}
.price-eyebrow {
  display:inline-block; font-family:'Syne',sans-serif;
  font-size:.68rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase;
  color:var(--cyan); margin-bottom:.6rem;
}
.price-tag {
  font-family:'Instrument Serif',serif; font-size:clamp(3.5rem,7vw,5.5rem);
  font-weight:400; line-height:1;
  background:linear-gradient(135deg, var(--sky), var(--cyan));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.price-period { font-size:.86rem; color:var(--text); margin:0.3rem 0 1.8rem; }
.price-feats { list-style:none; text-align:left; margin-bottom:2rem; }
.price-feats li {
  display:flex; align-items:center; gap:.75rem;
  padding:.72rem 0; border-bottom:1px solid var(--border-b);
  color:var(--text-med); font-size:.88rem;
}
.price-feats li:last-child { border-bottom:none; }
.price-feats li svg { color:var(--cyan); flex-shrink:0; width:16px; height:16px; }

/* ══════════════════════════════════════════
   WOMEN'S MONTH PROMO
══════════════════════════════════════════ */
#promo {
  background:linear-gradient(160deg, #100018 0%, #1a002c 50%, #100018 100%);
  position:relative; overflow:hidden; padding:clamp(4rem,8vw,7rem) 5%;
}
#promo::before {
  content:''; position:absolute; top:-100px; left:-100px;
  width:450px; height:450px; border-radius:50%;
  background:radial-gradient(circle, rgba(220,40,120,.15), transparent 65%);
  pointer-events:none; animation:pOrb1 9s ease-in-out infinite;
}
#promo::after {
  content:''; position:absolute; bottom:-80px; right:-80px;
  width:380px; height:380px; border-radius:50%;
  background:radial-gradient(circle, rgba(244,114,182,.12), transparent 65%);
  pointer-events:none; animation:pOrb2 11s ease-in-out infinite;
}
@keyframes pOrb1 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(35px,25px);} }
@keyframes pOrb2 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(-25px,-20px);} }
:root {
  --pink:#e8218a; --pink-light:#f472b6; --pink-dark:#c0166e;
}
.promo-container { max-width:1200px; margin:0 auto; position:relative; z-index:2; }
.promo-eyebrow {
  display:flex; align-items:center; justify-content:center; gap:.75rem; margin-bottom:2.4rem;
}
.promo-eyebrow-line {
  flex:1; max-width:120px; height:1px;
  background:linear-gradient(90deg, transparent, rgba(232,33,138,.5));
}
.promo-eyebrow-line.r { background:linear-gradient(90deg, rgba(232,33,138,.5), transparent); }
.promo-eyebrow-tag {
  font-family:'Syne',sans-serif; font-size:.68rem; font-weight:700;
  letter-spacing:.18em; text-transform:uppercase; color:var(--pink-light);
}
.promo-card {
  background:rgba(255,255,255,.03); border:1px solid rgba(232,33,138,.2);
  border-radius:var(--rad-lg); padding:clamp(2rem,4vw,3.2rem);
  position:relative; overflow:hidden; backdrop-filter:blur(8px);
  transition:border-color .4s, box-shadow .4s;
}
.promo-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg, transparent, var(--pink), var(--pink-light), var(--pink), transparent);
  background-size:200% 100%; animation:shimmer 3s linear infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.promo-card:hover { border-color:rgba(232,33,138,.45); box-shadow:0 24px 80px rgba(232,33,138,.15); }
.promo-layout {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(2rem,4vw,4rem); align-items:center;
}
.promo-title {
  font-family:'Instrument Serif',serif; font-size:clamp(2rem,5vw,3.8rem);
  font-weight:400; line-height:1.06; margin-bottom:.5rem;
  background:linear-gradient(135deg,#fff 0%,var(--pink-light) 50%,var(--pink) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.promo-title em { font-style:italic; display:block; font-size:.68em; }
.promo-theme {
  display:flex; align-items:flex-start; gap:.65rem;
  margin:1.2rem 0;
}
.promo-theme-dot {
  width:6px; height:6px; border-radius:50%; background:var(--pink);
  flex-shrink:0; margin-top:.45rem;
  animation:dotPulse 1.8s ease-in-out infinite;
}
@keyframes dotPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.8);opacity:.6;} }
.promo-theme p { font-size:clamp(.9rem,1.7vw,1.05rem); color:rgba(255,255,255,.72); font-style:italic; line-height:1.7; }
.promo-theme strong { color:var(--pink-light); font-style:normal; }
.promo-tagline {
  font-family:'Syne',sans-serif; font-size:clamp(1rem,2vw,1.3rem); font-weight:700;
  color:var(--pink-light); margin:1.4rem 0 1rem; line-height:1.35;
}
.promo-bullets { list-style:none; display:flex; flex-direction:column; gap:.65rem; margin-bottom:1.8rem; }
.promo-bullets li { display:flex; align-items:flex-start; gap:.65rem; font-size:.88rem; color:rgba(255,255,255,.78); line-height:1.65; }
.promo-icon {
  width:20px; height:20px; border-radius:50%; flex-shrink:0; margin-top:.15rem;
  background:rgba(232,33,138,.15); border:1px solid rgba(232,33,138,.3);
  display:flex; align-items:center; justify-content:center; color:var(--pink-light);
  font-size:.65rem;
}
.promo-badges { display:flex; flex-wrap:wrap; gap:.5rem; margin-bottom:1.8rem; }
.promo-badge {
  display:inline-flex; align-items:center; gap:.4rem;
  background:rgba(232,33,138,.1); border:1px solid rgba(232,33,138,.22);
  border-radius:50px; padding:.32rem .85rem;
  font-family:'Syne',sans-serif; font-size:.7rem; font-weight:700; color:var(--pink-light);
}
.btn-promo {
  display:inline-flex; align-items:center; gap:.6rem;
  background:linear-gradient(135deg, var(--pink-dark), var(--pink), var(--pink-light));
  background-size:200% 100%;
  color:#fff; font-family:'Syne',sans-serif; font-weight:700; font-size:.9rem;
  padding:.95rem 2.4rem; border-radius:50px; border:none; cursor:pointer;
  box-shadow:0 6px 32px rgba(232,33,138,.4);
  animation:promoShimmer 3s ease-in-out infinite;
  transition:transform .2s, box-shadow .2s; text-decoration:none;
}
.btn-promo:hover { transform:translateY(-3px); box-shadow:0 12px 48px rgba(232,33,138,.65); }
@keyframes promoShimmer { 0%,100%{background-position:0%} 50%{background-position:100%} }
.promo-valid { font-size:.74rem; color:rgba(255,255,255,.4); margin-top:.8rem; font-style:italic; }
/* promo image side */
.promo-img-wrap {
  position:relative; border-radius:var(--rad-lg); overflow:hidden;
  box-shadow:0 30px 80px rgba(232,33,138,.15), 0 0 0 1px rgba(232,33,138,.15);
  transition:transform .4s;
}
.promo-img-wrap:hover { transform:scale(1.02) translateY(-4px); }
.promo-img-wrap img { width:100%; display:block; }
.promo-disc {
  position:absolute; top:-18px; right:-18px; z-index:3;
  width:88px; height:88px; border-radius:50%;
  background:linear-gradient(135deg, var(--pink-dark), var(--pink));
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  box-shadow:0 8px 32px rgba(232,33,138,.6);
  animation:discPop 2.2s ease-in-out infinite;
}
.promo-disc span { font-weight:900; font-size:1.35rem; color:#fff; line-height:1; }
.promo-disc small { font-size:.6rem; font-weight:700; color:rgba(255,255,255,.85); letter-spacing:.06em; }
@keyframes discPop { 0%,100%{box-shadow:0 8px 32px rgba(232,33,138,.6);transform:scale(1);} 50%{box-shadow:0 12px 48px rgba(232,33,138,.9);transform:scale(1.06);} }
.promo-coach {
  position:absolute; bottom:-16px; left:-8px; z-index:3;
  display:flex; align-items:center; gap:.65rem;
  background:rgba(16,0,24,.9); border:1px solid rgba(232,33,138,.28);
  backdrop-filter:blur(12px); border-radius:50px;
  padding:.5rem 1.1rem .5rem .5rem;
  animation:chipFloat 4s ease-in-out infinite;
}
@keyframes chipFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-5px);} }
.promo-coach-av {
  width:34px; height:34px; border-radius:50%;
  background:linear-gradient(135deg, var(--pink-dark), var(--pink));
  display:flex; align-items:center; justify-content:center;
  font-family:'Syne',sans-serif; font-weight:700; font-size:.78rem; color:#fff;
  border:2px solid rgba(232,33,138,.4);
}
.promo-coach strong { display:block; font-size:.78rem; color:#fff; line-height:1.2; }
.promo-coach span { font-size:.66rem; color:rgba(255,255,255,.5); }
.promo-urgency {
  margin-top:2.4rem; display:flex; align-items:center; gap:1rem;
  background:rgba(232,33,138,.06); border:1px solid rgba(232,33,138,.16);
  border-radius:14px; padding:1rem 1.4rem;
}
.promo-urgency-icon {
  width:38px; height:38px; border-radius:10px; flex-shrink:0;
  background:rgba(232,33,138,.14); border:1px solid rgba(232,33,138,.22);
  display:flex; align-items:center; justify-content:center; color:var(--pink-light);
  animation:urgPulse 2s ease-in-out infinite;
}
@keyframes urgPulse { 0%,100%{background:rgba(232,33,138,.14);} 50%{background:rgba(232,33,138,.26);} }
.promo-urgency strong { display:block; font-size:.86rem; color:var(--pink-light); margin-bottom:.12rem; }
.promo-urgency span { font-size:.76rem; color:rgba(255,255,255,.45); }
.promo-countdown { margin-left:auto; text-align:right; }
.promo-countdown .dnum {
  font-family:'Instrument Serif',serif; font-size:2rem; line-height:1;
  background:linear-gradient(135deg,var(--pink-light),var(--pink));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.promo-countdown .dlbl { font-size:.62rem; color:rgba(255,255,255,.38); letter-spacing:.1em; text-transform:uppercase; }

/* ══════════════════════════════════════════
   LOCATION
══════════════════════════════════════════ */
#location { background:linear-gradient(170deg, var(--navy) 0%, var(--ink) 100%); }
.loc-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(1.5rem,3vw,3rem); align-items:start;
}
.map-wrap {
  border-radius:var(--rad-lg); overflow:hidden; border:1px solid var(--border);
  height:clamp(280px,45vw,420px);
}
.map-wrap iframe { width:100%; height:100%; border:none; display:block; }
.loc-cards { display:flex; flex-direction:column; gap:.85rem; }
.loc-card {
  display:flex; align-items:flex-start; gap:1rem;
  background:var(--glass); border:1px solid var(--border);
  border-radius:var(--rad-sm); padding:1.2rem 1.3rem;
  transition:background .2s;
}
.loc-card:hover { background:rgba(0,196,232,.07); }
.loc-icon {
  width:38px; height:38px; border-radius:10px; flex-shrink:0;
  background:rgba(0,196,232,.1); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center; color:var(--cyan);
}
.loc-lbl { font-family:'Syne',sans-serif; font-size:.62rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--cyan); margin-bottom:.25rem; }
.loc-val { font-size:.86rem; color:var(--text-med); line-height:1.55; }
.loc-val a { color:var(--text-med); }
.loc-val a:hover { color:var(--cyan); }

/* ══════════════════════════════════════════
   CONTACT
══════════════════════════════════════════ */
#contact { background:var(--ink); }
.contact-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(1.5rem,4vw,3.5rem); align-items:start;
}
.reach-btns { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; margin-bottom:1.2rem; }
.reach-btn {
  display:flex; align-items:center; gap:.75rem;
  padding:.9rem 1.1rem; border-radius:var(--rad-sm);
  transition:transform .2s, box-shadow .2s; text-decoration:none;
}
.reach-lbl { font-family:'Syne',sans-serif; font-weight:700; font-size:.82rem; color:#fff; line-height:1.2; }
.reach-sub { font-size:.68rem; color:rgba(255,255,255,.65); margin-top:.1rem; }
.reach-wa { background:#1da851; }
.reach-wa:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(29,168,81,.4); }
.reach-email {
  background:rgba(0,196,232,.1); border:1px solid rgba(0,196,232,.22);
}
.reach-email .reach-lbl { color:var(--cyan); }
.reach-email .reach-sub { color:var(--text); }
.reach-email:hover { background:rgba(0,196,232,.17); transform:translateY(-2px); }
.form-card {
  background:var(--glass); border:1px solid var(--border);
  border-radius:var(--rad-lg); padding:clamp(1.4rem,3vw,2.2rem);
}
.form-title {
  font-family:'Syne',sans-serif; font-size:1.05rem; font-weight:700;
  display:flex; align-items:center; gap:.6rem; margin-bottom:1.4rem; color:var(--white);
}
.form-title svg { color:var(--cyan); flex-shrink:0; width:18px; height:18px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:.8rem; }
.fgrp { display:flex; flex-direction:column; gap:.35rem; margin-bottom:.8rem; }
.fgrp:last-child { margin-bottom:0; }
.flbl { font-family:'Syne',sans-serif; font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.4); }
.finput, .fselect, .ftextarea {
  background:rgba(5,13,24,.7); border:1px solid var(--border);
  border-radius:var(--rad-sm); padding:.78rem 1rem;
  color:var(--white); font-family:'DM Sans',sans-serif; font-size:.9rem;
  outline:none; transition:border-color .2s, box-shadow .2s;
  -webkit-appearance:none; width:100%;
}
.finput:focus, .fselect:focus, .ftextarea:focus {
  border-color:var(--cyan); box-shadow:0 0 0 3px rgba(0,196,232,.1);
}
.ftextarea { resize:vertical; min-height:100px; }
.fselect { cursor:pointer; }
.form-btns { display:flex; gap:.75rem; margin-top:.85rem; flex-wrap:wrap; }
.btn-wa-send {
